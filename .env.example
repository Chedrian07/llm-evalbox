# ============================================================
#  llm-evalbox  .env.example
#  복사: cp .env.example .env  →  값 채우기
#  우선순위: CLI flag > 환경변수/.env > profile.toml > defaults
#
#  자세한 게이트웨이별 호환 매트릭스: docs/adapters.md
# ============================================================

# ---- Connection (필수 2종) ----
EVALBOX_BASE_URL=https://api.openai.com/v1
EVALBOX_MODEL=gpt-4o-mini

# ---- Adapter selection ----
# auto | chat_completions | responses
#   auto             = chat_completions (가장 광범위; vLLM/SGLang/Ollama/OpenRouter
#                      /Together/Fireworks/proxies 거의 모두 호환).
#   chat_completions = /v1/chat/completions 명시.
#   responses        = /v1/responses (OpenAI 본가 o-series / gpt-5 등). 일반
#                      게이트웨이는 미노출.
EVALBOX_ADAPTER=auto

# ---- API key ----
# 같은 이름이 여러 게이트웨이에서 쓰임. 한 .env 에 가장 흔한 키만 두고
# 다른 endpoint 는 --api-key-env 로 명시하는 게 단순.
OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# VLLM_KEY=                          # vLLM 은 키 검증 안 하지만 비워두면 거부하는 프록시도 있음

# ============================================================
#  ─── 자주 쓰는 게이트웨이 예시 ───
#
#  로컬 vLLM / SGLang (둘 다 OpenAI compat):
#    EVALBOX_BASE_URL=http://localhost:8000/v1
#    OPENAI_API_KEY=EMPTY
#    # 모델명 그대로 (Qwen/Qwen3-32B 등). chat_template_kwargs.enable_thinking 자동 처리.
#
#  Ollama:
#    EVALBOX_BASE_URL=http://localhost:11434/v1
#    OPENAI_API_KEY=ollama
#    EVALBOX_MODEL=llama3.2:latest
#
#  OpenRouter:
#    EVALBOX_BASE_URL=https://openrouter.ai/api/v1
#    OPENROUTER_API_KEY=sk-or-...
#    EVALBOX_MODEL=anthropic/claude-3.5-sonnet
#    # CLI: evalbox run --extra-header "HTTP-Referer=https://github.com/your/proj" ...
#
#  Together:
#    EVALBOX_BASE_URL=https://api.together.xyz/v1
#    TOGETHER_API_KEY=...
#
#  Fireworks:
#    EVALBOX_BASE_URL=https://api.fireworks.ai/inference/v1
#    FIREWORKS_API_KEY=...
#
#  OpenAI 본가 (Responses API 명시 필요할 때):
#    EVALBOX_BASE_URL=https://api.openai.com/v1
#    EVALBOX_MODEL=o3-mini
#    EVALBOX_ADAPTER=responses
# ============================================================

# ---- Sampling override (있으면 결정성 강제 해제) ----
EVALBOX_TEMPERATURE=
EVALBOX_TOP_P=
EVALBOX_TOP_K=
EVALBOX_REASONING_EFFORT=         # minimal | low | medium | high | xhigh
# EVALBOX_STRICT_DETERMINISTIC=1

# ---- Thinking (3단) ----
EVALBOX_THINKING=auto             # auto | on | off

# ---- Capability override ----
# doctor 의 4xx 학습이 출력하는 키들을 여기에 명시하면 run 시 자동 strip.
EVALBOX_DROP_PARAMS=              # 콤마 구분, e.g. top_k,stop

# ---- Rate limit / 동시성 ----
EVALBOX_RPM=
EVALBOX_TPM=
EVALBOX_CONCURRENCY=8
EVALBOX_SANDBOX_WORKERS=4

# ---- 코드 sandbox ----
EVALBOX_SANDBOX=subprocess        # subprocess | docker | e2b
EVALBOX_ACCEPT_CODE_EXEC=         # 1 = 비대화형 동의 (CI)
# E2B_API_KEY=

# ---- 데이터셋 / 캐시 ----
EVALBOX_DATASETS_DIR=             # 비우면 패키지 번들 → ~/.cache/llm-evalbox/datasets
EVALBOX_CACHE_DIR=                # 비우면 ~/.cache/llm-evalbox
EVALBOX_NO_CACHE=                 # 1 이면 응답 캐시 비활성

# ---- 비용 가드 ----
EVALBOX_MAX_COST_USD=

# ---- Web ----
EVALBOX_WEB_HOST=127.0.0.1
EVALBOX_WEB_PORT=8765
EVALBOX_WEB_OPEN_BROWSER=1
# EVALBOX_WEB_BIND_TOKEN=

# ---- 로깅 ----
EVALBOX_LOG_LEVEL=                # WARNING | INFO | DEBUG
