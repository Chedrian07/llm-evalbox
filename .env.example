# ============================================================
#  llm-evalbox  .env.example
#  Copy: cp .env.example .env  →  fill in the values
#  Priority: CLI flag > env var / .env > profile.toml > package defaults
#
#  Per-gateway compatibility matrix: docs/adapters.md
# ============================================================

# ---- Connection (the two required fields) ----
EVALBOX_BASE_URL=https://api.openai.com/v1
EVALBOX_MODEL=gpt-4o-mini

# ---- Adapter selection ----
# auto | chat_completions | responses
#   auto             = chat_completions (broadest compatibility — works with
#                      vLLM/SGLang/Ollama/OpenRouter/Together/Fireworks/proxies).
#   chat_completions = explicit /v1/chat/completions.
#   responses        = /v1/responses (OpenAI public o-series / gpt-5).
#                      Most other gateways do not expose this route.
EVALBOX_ADAPTER=auto

# ---- API key ----
# The same key name is reused across many gateways. Keep the most common one
# in .env and reach for --api-key-env to point at a different env var per run.
OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# VLLM_KEY=                        # vLLM doesn't validate keys, but some proxies in front of it do

# ============================================================
#  ─── Common gateway recipes ───
#
#  Local vLLM / SGLang (both OpenAI-compat):
#    EVALBOX_BASE_URL=http://localhost:8000/v1
#    OPENAI_API_KEY=EMPTY
#    # Pass the full model name (e.g. Qwen/Qwen3-32B). chat_template_kwargs.enable_thinking is wired automatically.
#
#  Ollama:
#    EVALBOX_BASE_URL=http://localhost:11434/v1
#    OPENAI_API_KEY=ollama
#    EVALBOX_MODEL=llama3.2:latest
#
#  OpenRouter:
#    EVALBOX_BASE_URL=https://openrouter.ai/api/v1
#    OPENROUTER_API_KEY=sk-or-...
#    EVALBOX_MODEL=anthropic/claude-3.5-sonnet
#    # CLI: evalbox run --extra-header "HTTP-Referer=https://github.com/your/proj" ...
#
#  Together:
#    EVALBOX_BASE_URL=https://api.together.xyz/v1
#    TOGETHER_API_KEY=...
#
#  Fireworks:
#    EVALBOX_BASE_URL=https://api.fireworks.ai/inference/v1
#    FIREWORKS_API_KEY=...
#
#  OpenAI public (Responses API explicit):
#    EVALBOX_BASE_URL=https://api.openai.com/v1
#    EVALBOX_MODEL=o3-mini
#    EVALBOX_ADAPTER=responses
# ============================================================

# ---- Sampling override (any value here disables the deterministic default) ----
EVALBOX_TEMPERATURE=
EVALBOX_TOP_P=
EVALBOX_TOP_K=
EVALBOX_REASONING_EFFORT=         # none | minimal | low | medium | high | xhigh
# EVALBOX_STRICT_DETERMINISTIC=1

# ---- Thinking (3 modes) ----
EVALBOX_THINKING=auto             # auto | on | off

# ---- Capability override ----
# When `evalbox doctor` learns drop_params from a 4xx, list them here so
# subsequent runs strip those keys before they hit the wire.
EVALBOX_DROP_PARAMS=              # comma-separated, e.g. top_k,stop

# ---- Rate limit / concurrency ----
EVALBOX_RPM=
EVALBOX_TPM=
EVALBOX_CONCURRENCY=8
EVALBOX_SANDBOX_WORKERS=4

# ---- Code sandbox ----
EVALBOX_SANDBOX=subprocess        # subprocess | docker | e2b
EVALBOX_ACCEPT_CODE_EXEC=         # 1 = non-interactive consent (CI)
# E2B_API_KEY=

# ---- Datasets / cache ----
EVALBOX_DATASETS_DIR=             # empty → bundled datasets in the wheel, then ~/.cache/llm-evalbox/datasets
EVALBOX_CACHE_DIR=                # empty → ~/.cache/llm-evalbox
EVALBOX_CONFIG_DIR=               # empty → ~/.config/llm-evalbox
# EVALBOX_DATA_DIR=/data          # parent for cache + config — set in Docker
EVALBOX_NO_CACHE=                 # 1 disables the response cache

# ---- Cost guardrail ----
EVALBOX_MAX_COST_USD=

# ---- Web ----
# `evalbox web` auto-loads this file. The SPA reads non-secret values from
# GET /api/defaults at mount; API key values are NEVER returned, only
# `has_api_key` / per-env presence flags.
EVALBOX_WEB_HOST=127.0.0.1
EVALBOX_WEB_PORT=8765
EVALBOX_WEB_OPEN_BROWSER=1
# EVALBOX_WEB_BIND_TOKEN=

# ---- Run-mode toggles also picked up by the Web UI ----
# EVALBOX_STRICT_FAILURES=1         # academic mode: count sandbox/network failures
# EVALBOX_NO_THINKING_RERUN=1       # disable the auto rerun for truncated thinking
# EVALBOX_PROMPT_CACHE_AWARE=1      # prepend a stable system prefix
# EVALBOX_PROFILE=                  # name from profiles.toml
#
# Fast GPT-5-compatible proxy recipe:
#   EVALBOX_THINKING=off
#   EVALBOX_REASONING_EFFORT=none
#   EVALBOX_NO_THINKING_RERUN=1

# ---- Logging ----
EVALBOX_LOG_LEVEL=                # WARNING | INFO | DEBUG
